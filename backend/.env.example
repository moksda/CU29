# ── Server ───────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_ORIGIN=http://localhost:8099

# ── Session ───────────────────────────────────────────────────────
# Generate with: node -e "require('crypto').randomBytes(64).toString('hex')"
SESSION_SECRET=replace_with_random_64_char_hex_string

# ── Google Apps Script ────────────────────────────────────────────
APPS_SCRIPT_URL=your_apps_script_deployment_url_here

# ── Market data ───────────────────────────────────────────────────
FINNHUB_TOKEN=your_finnhub_api_key_here

# ── Admin account ─────────────────────────────────────────────────
ADMIN_EMAIL=your_admin_email_here
# Generate hash with: node -e "require('bcrypt').hash('YourPassword',12).then(console.log)"
ADMIN_PASSWORD_HASH=replace_with_bcrypt_hash_of_admin_password
